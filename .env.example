# Network: "devnet" | "localnet" | "mainnet-beta"
VITE_SOLANA_NETWORK=devnet

# RPC endpoint override (optional — defaults based on network)
VITE_RPC_URL=

# Program ID
VITE_PROGRAM_ID=DQ1tBHL6cmuUtYAbxvTVvvaNEZtXP1byKeb51gvxWvr2

# Collection address (from initialize instruction output)
VITE_COLLECTION_ADDRESS=

# Treasury wallet (SOL recipient for mints, boosts, marketplace fees)
VITE_TREASURY=

# Pinata IPFS (for image uploads)
VITE_PINATA_JWT=
VITE_PINATA_GATEWAY=

# Use DAS API (getAssetsByGroup) to list Core assets instead of raw
# getProgramAccounts. Set to "true" when VITE_RPC_URL is a DAS-compatible
# endpoint (Helius, Triton, Shyft). Required for production performance —
# mainnet public RPC takes ~25s for the gPA scan.
VITE_USE_DAS=
